{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deva Light",
  "version": "0.2.1",
  "identifier": "com.deva-light.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": null,
    "beforeBuildCommand": null
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Deva Light",
        "width": 64,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "Deva Light Settings",
        "url": "settings.html",
        "width": 860,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "center": true
      },
      {
        "label": "news",
        "title": "休息一下",
        "url": "news.html",
        "width": 440,
        "height": 600,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.ico", "icons/icon.png", "icons/icon.icns"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM5NzVGREFDQkQ0RkZFOEEKUldTSy9rKzlyUDExT2ZKVkg1b3I3bVB1Vk1ndm9laUdnZ3pyYm1laFgrMUdNWWFGRTJOaFlOU0QK",
      "endpoints": [
        "https://github.com/wybyMrH/Deva_Light/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
